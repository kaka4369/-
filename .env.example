# Core
APP_ENV=development
CANVAS_PRODUCTION=0
INVITE_CODE=canvasv1
SESSION_SECRET=replace-with-a-long-random-secret
# Stable secret used to encrypt admin-managed provider keys at rest. Production
# requires at least 32 characters before provider keys can be saved.
CONFIG_ENCRYPTION_KEY=
AUTO_ADMIN_FIRST_USER=1
DEFAULT_CREDITS=100
PORT=3020
COOKIE_SECURE=0
ADMIN_HOST=
AUTH_RATE_LIMIT_MAX=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
TASK_WORKER_ENABLED=1
TASK_WORKER_CONCURRENCY=2
TASK_LEASE_SECONDS=120
TASK_LEASE_HEARTBEAT_SECONDS=30
TASK_MAX_ATTEMPTS=3
MAX_OUTPUT_MB=500
MAX_USER_STORAGE_MB=2048

# Data paths. In Docker these map to mounted volumes.
DATA_DIR=./data
STORAGE_DIR=./storage

# Credit costs
COST_LLM=1
COST_IMAGE=5
COST_VIDEO=40

# LLM provider
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Optional full chat completions endpoint override
LLM_CHAT_URL=

# Image provider
IMAGE_API_KEY=
IMAGE_GENERATION_URL=
IMAGE_MODEL=gpt-image-1

# Video provider
VIDEO_API_KEY=
VIDEO_GENERATION_URL=https://llm.guohe-sh.com/api/doubao/v3/contents/generations/tasks
VIDEO_MODEL=doubao-seedance-2-0-260128
VIDEO_STATUS_URL_TEMPLATE=https://llm.guohe-sh.com/api/doubao/v3/contents/generations/tasks/{task_id}
VIDEO_POLL_INTERVAL_SECONDS=3
VIDEO_POLL_TIMEOUT_SECONDS=1800

# Optional named providers used by the provider selectors.
OPENAI_LLM_API_KEY=
OPENAI_LLM_BASE_URL=
OPENAI_LLM_CHAT_URL=
OPENAI_LLM_MODEL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_CHAT_URL=
CUSTOM_LLM_MODEL=
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_GENERATION_URL=
OPENAI_IMAGE_MODEL=
CUSTOM_IMAGE_API_KEY=
CUSTOM_IMAGE_GENERATION_URL=
CUSTOM_IMAGE_MODEL=
VOLCANO_VIDEO_API_KEY=
VOLCANO_VIDEO_GENERATION_URL=
VOLCANO_VIDEO_STATUS_URL_TEMPLATE=
VOLCANO_VIDEO_MODEL=
CUSTOM_VIDEO_API_KEY=
CUSTOM_VIDEO_GENERATION_URL=
CUSTOM_VIDEO_STATUS_URL_TEMPLATE=
CUSTOM_VIDEO_MODEL=
