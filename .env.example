# Core
INVITE_CODE=canvasv1
SESSION_SECRET=replace-with-a-long-random-secret
AUTO_ADMIN_FIRST_USER=1
DEFAULT_CREDITS=100
PORT=3020
COOKIE_SECURE=0

# Data paths. In Docker these map to mounted volumes.
DATA_DIR=./data
STORAGE_DIR=./storage

# Credit costs
COST_LLM=1
COST_IMAGE=5
COST_VIDEO=40

# LLM provider
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Optional full chat completions endpoint override
LLM_CHAT_URL=

# Image provider
IMAGE_API_KEY=
IMAGE_GENERATION_URL=
IMAGE_MODEL=gpt-image-1

# Video provider
VIDEO_API_KEY=
VIDEO_GENERATION_URL=
VIDEO_MODEL=seedance-2.0
